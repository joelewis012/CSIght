# CSIght ESP32 sdkconfig defaults
# Safe settings — do NOT modify bootloader or partition table entries

# WiFi
CONFIG_ESP_WIFI_STATIC_RX_BUFFER_NUM=10
CONFIG_ESP_WIFI_DYNAMIC_RX_BUFFER_NUM=32
CONFIG_ESP_WIFI_CSI_ENABLED=y
CONFIG_ESP_WIFI_AMPDU_RX_ENABLED=y

# UART
CONFIG_ESP_CONSOLE_UART_DEFAULT=y
CONFIG_ESP_CONSOLE_UART_NUM=0

# FreeRTOS
CONFIG_FREERTOS_HZ=1000

# Compiler — keep strict
CONFIG_COMPILER_OPTIMIZATION_SIZE=y

# Partition table — two OTA slots + otadata, enables wireless firmware
# updates on the primary via the web dashboard (v3.1+).
#
# IMPORTANT: this changes the flash layout. Boards already flashed with an
# older CSIght build (single-app partition table) MUST be fully re-flashed
# once via USB/esptool or the Flipper's Flash Firmware feature before OTA
# will work — you cannot OTA your way onto a new partition table, since the
# bootloader itself needs the new partition map. After that one-time
# re-flash, OTA updates work normally from then on.
CONFIG_PARTITION_TABLE_TWO_OTA=y

# NVS
CONFIG_NVS_ENCRYPTION=n
